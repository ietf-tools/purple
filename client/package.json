{
  "name": "nuxt-app",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "build:dev": "nuxt prepare && nuxt build --envName development",
    "cleanup": "nuxt cleanup",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "test": "npm run test:unittests && npm run test:types",
    "test:unittests": "vitest run",
    "test:unittests:watch": "vitest",
    "test:types": "nuxt prepare && npx nuxt typecheck"
  },
  "dependencies": {
