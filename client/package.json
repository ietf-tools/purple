    "@vueuse/core": "14.0.0",
    "canvas-confetti": "1.9.4",
    "d3": "7.9.0",
    "defu": "6.1.7",
    "es-toolkit": "1.49.0",
    "fluid-dnd": "2.6.3",
    "fuse.js": "7.1.0",
    "humanize-duration": "3.33.1",
    "luxon": "3.7.2",
    "nuxt-snackbar": "1.3.0",
    "pinia": "3.0.4",
    "reka-ui": "2.9.4",
    "sortablejs": "1.15.7",
    "sortablejs-vue3": "1.3.0",
    "vue": "3.5.35"
  },
  "devDependencies": {
    "@nuxt/devtools": "3.2.4",
    "@nuxt/icon": "2.1.0",
    "@nuxt/test-utils": "4.0.3",
    "@nuxtjs/color-mode": "4.0.0",
    "@nuxtjs/robots": "5.5.6",
    "@nuxtjs/tailwindcss": "6.14.0",
    "@pinia/nuxt": "0.11.3",
    "@tailwindcss/forms": "0.5.10",
    "@types/canvas-confetti": "1.9.0",
    "@types/d3": "7.4.3",
    "@types/humanize-duration": "3.27.4",
    "@types/luxon": "3.7.1",
    "@types/node": "22.15.30",
    "@types/sortablejs": "1.15.9",
    "@vue/test-utils": "2.4.6",
    "commander": "13.1.0",
    "globals": "17.4.0",
    "happy-dom": "20.9.0",
    "nuxt": "4.4.7",
    "nuxt-headlessui": "1.2.2",
    "nuxt-security": "2.5.1",
    "nuxt-svgo": "5.3.0",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "oxlint-tsgolint": "0.25.0",
